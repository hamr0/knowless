{
  "name": "knowless",
  "version": "0.2.0",
  "description": "Small, opinionated, full-stack passwordless auth for Node.js services that don't need to email their users for anything but the sign-in link.",
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "bin": {
    "knowless-server": "./bin/knowless-server"
  },
  "files": [
    "src/",
    "bin/",
    "config.example.env",
    "LICENSE",
    "NOTICE",
    "README.md",
    "CHANGELOG.md",
    "GUIDE.md",
    "OPS.md",
    "knowless.context.md"
  ],
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "test": "node --test 'test/**/*.test.js'",
    "lint": "find src bin -type f \\( -name '*.js' -o -name 'knowless-server' \\) -exec node --check {} \\;"
  },
  "dependencies": {
    "nodemailer": "^8.0.7"
  },
  "license": "Apache-2.0",
  "homepage": "https://github.com/hamr0/knowless",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hamr0/knowless.git"
  },
  "bugs": {
    "url": "https://github.com/hamr0/knowless/issues"
  },
  "keywords": [
    "auth",
    "authentication",
    "passwordless",
    "magic-link",
    "forward-auth",
    "self-hosted",
    "privacy"
  ]
}
